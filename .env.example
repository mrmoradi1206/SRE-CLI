# Copy this file to .env and fill in your values.
# API keys are read ONLY from the environment. Do not commit your real .env.

# --- Prometheus ---
# Base URL of the Prometheus server.
# Local run: http://localhost:9090
# Inside docker-compose: http://prometheus:9090
PROM_URL=http://localhost:9090

# Path to the memory file (jobs/metrics/targets snapshot from /discover).
MEMORY_FILE=memory.json

# --- Provider selection ---
# Active provider: gapgpt | openrouter
PROVIDER=openrouter

# Active model id (must support tool/function calling).
MODEL=openai/gpt-4o-mini

# --- API keys (set the one matching PROVIDER) ---
OPENROUTER_API_KEY=
GAPGPT_API_KEY=

# --- Optional base-URL overrides (defaults are usually fine) ---
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GAPGPT_BASE_URL=https://api.gapgpt.app/v1
